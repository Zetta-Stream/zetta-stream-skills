{
  "name": "zetta-stream",
  "version": "0.1.0",
  "description": "Zetta-Stream — Intent-Based Autonomous Yield Stream Gateway. AI agent rotates USDC between Aave V3 and Uniswap V4 driven by x402 V2 yield signals + EIP-7702 batches + TEE firewall. Built for the OKX Onchain OS Hackathon.",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "agent": "tsx agent/index.ts",
    "agent:start": "tsx agent/index.ts",
    "agent:demo": "tsx agent/index.ts --mode demo",
    "agent:monitor": "tsx agent/index.ts --mode monitor",
    "agent:execute-once": "tsx agent/index.ts --mode execute-once",
    "agent:mock-x402": "tsx agent/x402/mock-server.ts",
    "contracts:test": "cd contracts && forge test -vvv",
    "contracts:build": "cd contracts && forge build",
    "contracts:deploy:log": "cd contracts && forge script script/DeployZettaStreamLog.s.sol --rpc-url $XLAYER_RPC_URL --private-key $DEPLOYER_PRIVATE_KEY --broadcast",
    "contracts:deploy:medal": "cd contracts && forge script script/DeployZettaStreamMedal.s.sol --rpc-url $XLAYER_RPC_URL --private-key $DEPLOYER_PRIVATE_KEY --broadcast",
    "contracts:deploy:delegate": "cd contracts && forge script script/DeployZettaStreamDelegate.s.sol --rpc-url $EXEC_CHAIN_RPC_URL --private-key $DEPLOYER_PRIVATE_KEY --broadcast",
    "contracts:deploy": "pnpm contracts:deploy:log && pnpm contracts:deploy:medal && pnpm contracts:deploy:delegate",
    "seed:rotations": "tsx scripts/seed-rotation-log.ts",
    "verify": "tsx scripts/verify.ts",
    "verify:wallet": "tsx scripts/verify-wallet.ts",
    "wallet:generate": "tsx scripts/generate-agent-wallet.ts",
    "dev:all": "concurrently -n agent,mock,web -c green,yellow,cyan \"pnpm agent:monitor\" \"pnpm agent:mock-x402\" \"pnpm dev\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@rainbow-me/rainbowkit": "^2.2.0",
    "@tanstack/react-query": "^5.59.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "execa": "^8.0.1",
    "hono": "^4.6.14",
    "lucide-react": "^0.468.0",
    "next": "^16.0.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.5.4",
    "viem": "^2.21.55",
    "wagmi": "^2.13.3",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20.17.10",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.0"
}
