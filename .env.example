# ---- OKX Onchain OS (TEE Agentic Wallet) ----
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# ---- X Layer (primary chain for audit + batch delegate) ----
XLAYER_RPC_URL=https://rpc.xlayer.tech
XLAYER_CHAIN_ID=196
# Used ONLY to forge-deploy the two contracts. Never used by the agent runtime.
# Agent runtime signing always goes through the OKX Agentic Wallet TEE.
DEPLOYER_PRIVATE_KEY=

# ---- Deployed contract addresses (fill after `pnpm contracts:deploy`) ----
ZETTA_STREAM_LOG_ADDRESS=
BATCH_CALL_DELEGATE_ADDRESS=

# ---- EIP-7702 demo EOA ----
# The EOA that signs the 7702 authorization. Owned by the demo; NEVER a user key.
# Disclosed in README. viem's signAuthorization requires a local account (not TEE).
DEMO_EOA_PRIVATE_KEY=
DEMO_EOA_ADDRESS=

# ---- Mock phishing fixture (scenario 1) ----
PHISHING_VAULT_ADDRESS=

# ---- x402 ----
# Either a real facilitator URL or our local mock server.
X402_FACILITATOR_URL=http://localhost:4402
X402_ASSET_ADDRESS=0x4ae46a509f6b1d9056937ba4500cb143933d2dc8
X402_PAYTO_ADDRESS=
X402_PAYMENT_AMOUNT=1000
X402_MOCK_SERVER_PORT=4402

# ---- Agent tuning ----
POLL_INTERVAL_MS=500
MIN_CONFIDENCE_APPROVE=60
SILENT_MODE=false
DEMO_MODE=true

# ---- Agent API ----
AGENT_API_PORT=7777
AGENT_STATE_PATH=./.agent-state.json
AGENT_LOG_PATH=./logs/agent.jsonl

# ---- Frontend ----
NEXT_PUBLIC_XLAYER_RPC=https://rpc.xlayer.tech
NEXT_PUBLIC_ZETTA_STREAM_LOG_ADDRESS=
NEXT_PUBLIC_BATCH_CALL_DELEGATE_ADDRESS=
NEXT_PUBLIC_AGENT_API_URL=http://localhost:7777
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
