# ---- OKX Onchain OS (TEE Agentic Wallet) ----
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# ---- X Layer (audit + Medal NFT) ----
XLAYER_RPC_URL=https://rpc.xlayer.tech
XLAYER_CHAIN_ID=196
# Used ONLY to forge-deploy contracts. Never used by the agent runtime.
# Agent runtime signing always goes through the OKX Agentic Wallet TEE.
DEPLOYER_PRIVATE_KEY=

# ---- Execution chain (Arbitrum: UniV4 + Aave V3 + Pectra/EIP-7702 live) ----
EXEC_CHAIN_RPC_URL=https://arb1.arbitrum.io/rpc
EXEC_CHAIN_ID=42161
# USDC on Arbitrum (native, not bridged)
USDC_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831
# Aave V3 Pool on Arbitrum
AAVE_V3_POOL=0x794a61358D6845594F94dc1DB02A252b5b4814aD
# Uniswap V4 PositionManager on Arbitrum (set after V4 deploy is finalized for chain)
UNI_V4_POSITION_MANAGER=
UNI_V4_POOL_KEY_TOKEN0=
UNI_V4_POOL_KEY_TOKEN1=
UNI_V4_POOL_KEY_FEE=500
UNI_V4_POOL_KEY_TICKSPACING=10
UNI_V4_POOL_KEY_HOOKS=0x0000000000000000000000000000000000000000
# Optional OKX DEX aggregator router on Arbitrum (added to Delegate allowlist)
OKX_DEX_ROUTER=
ARBISCAN_API_KEY=

# ---- Deployed contract addresses (fill after `pnpm contracts:deploy:*`) ----
ZETTA_STREAM_LOG_ADDRESS=
ZETTA_STREAM_MEDAL_ADDRESS=
ZETTA_STREAM_DELEGATE_ADDRESS=
# Multisig key allowed to call Delegate.setAllowed (use deployer EOA in dev)
DELEGATE_FACTORY_ADDRESS=
# Owner of the Medal NFT — agent EOA that mints
MEDAL_OWNER_ADDRESS=

# ---- EIP-7702 demo EOA ----
# The EOA that signs the 7702 authorization. Owned by the demo; NEVER a user key.
# Disclosed in README. viem's signAuthorization requires a local account (not TEE).
DEMO_EOA_PRIVATE_KEY=
DEMO_EOA_ADDRESS=

# ---- x402 yield-feed session ----
# Local mock server in dev. In production, points at a real x402 facilitator.
X402_FACILITATOR_URL=http://localhost:8402
X402_ASSET_ADDRESS=0x4ae46a509f6b1d9056937ba4500cb143933d2dc8
X402_PAYTO_ADDRESS=
X402_PAYMENT_AMOUNT=100000
X402_MOCK_SERVER_PORT=8402

# ---- Decision engine tuning ----
POLL_INTERVAL_MS=15000
MIN_CONFIDENCE_APPROVE=60
DWELL_SECONDS=180
COOLDOWN_SECONDS=1800
YIELD_MIN_SPREAD_BPS=30
ESTIMATED_GAS_USD=0.50
NOTIONAL_USD=200

# ---- Flags ----
SILENT_MODE=false
FORCE_7702=false
LOCAL_SIGN_FALLBACK=false
DEMO_MODE=true

# ---- Agent API ----
AGENT_API_PORT=7777
AGENT_STATE_PATH=./.agent-state.json
AGENT_LOG_PATH=./logs/agent.jsonl

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_XLAYER_RPC=https://rpc.xlayer.tech
NEXT_PUBLIC_EXEC_CHAIN_RPC=https://arb1.arbitrum.io/rpc
NEXT_PUBLIC_ZETTA_STREAM_LOG_ADDRESS=
NEXT_PUBLIC_ZETTA_STREAM_MEDAL_ADDRESS=
NEXT_PUBLIC_ZETTA_STREAM_DELEGATE_ADDRESS=
NEXT_PUBLIC_AGENT_API_URL=http://localhost:7777
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
